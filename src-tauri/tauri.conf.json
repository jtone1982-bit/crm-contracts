{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CRM Контракты",
  "version": "1.0.0",
  "identifier": "ru.tone.crmcontracts",
  "build": {
    "frontendDist": "https://tone-crm.ru",
    "devUrl": "https://tone-crm.ru",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "CRM Контракты",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
